# Root-level gitignore

# Dependency directories
node_modules/
client/node_modules/
server/node_modules/

# Local History folder (e.g. VS Code Local History extension)
.history/

# Environment variables
.env
client/.env
server/.env

# Build directories
dist/
client/dist/
dist-ssr/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and OS Specific files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
